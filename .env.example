BINANCE_API_KEY=your-api-key
BINANCE_API_SECRET=your-api-secret
BINANCE_BASE_URL=https://papi.binance.com
# Optional explicit websocket override. Leave empty to derive from BINANCE_BASE_URL.
BINANCE_WS_BASE_URL=
CANDIDATE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
PRIMARY_BAR_INTERVAL=5m
TARGET_NOTIONAL=1000
LONG_TAKE_PROFIT=25
SHORT_TAKE_PROFIT=25
LIVE_DRY_RUN=true
LIVE_LOG_PATH=tmp/live_runtime.jsonl
LIVE_LOG_ROTATE_DAILY=true
LIVE_USER_STREAM_RETRY_ATTEMPTS=2
LIVE_USER_STREAM_RETRY_BACKOFF_SECONDS=1.0
LIVE_USER_STREAM_RETRY_BACKOFF_MULTIPLIER=2.0
LIVE_CYCLE_RETRY_ATTEMPTS=2
LIVE_CYCLE_RETRY_BACKOFF_SECONDS=1.0
LIVE_CYCLE_RETRY_BACKOFF_MULTIPLIER=2.0
RISK_SOFT_UNIMMR=6
RISK_HARD_UNIMMR=4
RISK_MAX_DRAWDOWN=0.15
RISK_REDEEM_UNIMMR=6
TRANSFER_MIN_SWEEP=50
TRANSFER_PM_RESERVE=100
TRANSFER_MIN_REDEEM=50
